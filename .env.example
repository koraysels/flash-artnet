# Kopieer naar .env en vul in. .env staat in .gitignore (wordt NOOIT gecommit).
# De scripts laden dit automatisch (python-dotenv).

# MQTT-broker (mosquitto, Komodo-stack flash-mqtt)
MQTT_HOST=100.71.177.9
MQTT_PORT=1883
MQTT_USER=flash
MQTT_PASS=changeme

# Snelheidsdrempel - FALLBACK (km/u) als de payload geen maxSpeedKmh meebrengt.
# SPEED_LIMIT_DEFAULT=120

# Flits-delay (s) - FALLBACK als de payload geen hls_latency_s meebrengt.
# Zet ~ de HLS-latency zodat de flits samenvalt met het beeld op de schermen.
# FLASH_DELAY=6.0

# Art-Net (optioneel; defaults staan in de scripts)
# ARTNET_IP=192.168.0.111
# ARTNET_UNIVERSE=0
